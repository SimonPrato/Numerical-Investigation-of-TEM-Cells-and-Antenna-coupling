\contentsline {figure}{\numberline {5.7}{\ignorespaces Surface current densities at (a) 3\,GHz, where only the TEM mode propagates, and (b) 3.3\,GHz, above the cut-off frequency of the TE\textsubscript {01} mode, where this higher-order mode is excited and the TEM mode contribution has been compensated.}}{52}{figure.caption.35}%
\contentsline {figure}{\numberline {5.8}{\ignorespaces Electric field component $E^\pm _\mathrm {y}$ at $x=0$, $y=b/4$, $z=\pm l/2$ and the corresponding output power in (a). The output power of the monopole antenna is compared against that produced by the equivalent dipole moments in (b) to validate the model.}}{53}{figure.caption.36}%
\contentsline {figure}{\numberline {5.9}{\ignorespaces Equivalent circuit for a short electric dipole models the monopole antenna's behavior.}}{53}{figure.caption.37}%
\contentsline {figure}{\numberline {5.10}{\ignorespaces Model of the monopole antenna connected to a feedpoint mounted on a PEC surface with a side length of $\lambda /2$ and height of $\lambda /4$, where $\lambda $ corresponds to the free-space wavelength of the smallest investigated frequency. This configuration enables the investigation of the monopole antenna reactance without influence of the TEM cell.}}{54}{figure.caption.38}%
\contentsline {figure}{\numberline {5.11}{\ignorespaces Circuit representing the TEM cell and the monopole antenna, with the additional components $C_k$ and $M_{A,T1}$, $M_{A,T2}$ modeling their near-field coupling behavior.}}{55}{figure.caption.39}%
\contentsline {figure}{\numberline {5.12}{\ignorespaces Equivalent dipole moments derived by the equivalent circuit compared to the previously derived dipole moments of the monopole antenna, shown in \autoref {fig:dipolemomentsmonopolewide}. The electric dipole moment $\mathbf {m}_e$ is weighted with $\eta _0$ for comparison purposes.}}{56}{figure.caption.40}%
\contentsline {figure}{\numberline {5.13}{\ignorespaces The geometry of the loop antenna is presented in (b). The electric near-field is demonstrated in (a). This figure is not to scale.}}{58}{figure.caption.41}%
\contentsline {figure}{\numberline {5.14}{\ignorespaces Equivalent electric and magnetic dipole moments of the loop antenna as a function of frequency in (a), and the related phase of the power at each output port in (b)}}{59}{figure.caption.42}%
\contentsline {figure}{\numberline {5.15}{\ignorespaces Numerical model of a TEM cell containing an electric dipole moment $\mathbf {m}_e$ and a magnetic dipole moment $\mathbf {m}_m$ positioned at the center ($x=0,\,y=r=b/4,\,z=0$). This setup is used to investigate whether the dominant coupling field region influences the output power.}}{59}{figure.caption.43}%
\contentsline {figure}{\numberline {5.16}{\ignorespaces The $k \cdot r$ factor as a function of frequency for the large ($r = b/4 = 6\,\mathrm {mm}$) and small ($r = b/4 = 1.5\,\mathrm {mm}$) TEM cells.}}{60}{figure.caption.44}%

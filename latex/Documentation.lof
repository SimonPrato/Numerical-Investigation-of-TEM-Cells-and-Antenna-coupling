\contentsline {figure}{\numberline {2.2}{\ignorespaces The geometry of a linear, center-fed wire antenna is depicted with the feedpoint located at its center. The feedpoint is represented by a small gap through which a current $I_0$ is supplied to the antenna \blx@tocontentsinit {0}\cite [p.~417]{Jackson}.}}{6}{figure.caption.5}%
\contentsline {figure}{\numberline {2.3}{\ignorespaces The current distribution along a linear wire antenna reaches its maximum at the feedpoint and decreases to zero at the endpoints, located at $d/2$ and $-d/2$ \blx@tocontentsinit {0}\cite [p. 163]{Balanis_1997}.}}{7}{figure.caption.6}%
\contentsline {figure}{\numberline {2.4}{\ignorespaces Current loop of radius $b$ carrying a current $I_0$, and its equivalent representation as a magnetic current $I_m$ flowing perpendicular to the plane of the loop over a distance $L$, producing the magnetic dipole moment $\mathbf {m}_m$.}}{7}{figure.caption.7}%
\contentsline {figure}{\numberline {2.5}{\ignorespaces The behavior of Expression 1 and Expression 2 in (\ref {eqn:e_et_2}) is analyzed as a function of distance $r$. Here, $r$ is normalized to the radian distance $\lambda / 2\pi $, and the magnitudes of both expressions are scaled to unity at the radian distance to facilitate comparison \blx@tocontentsinit {0}\cite [p.~157]{Balanis_1997}.}}{9}{figure.caption.8}%
\contentsline {figure}{\numberline {2.6}{\ignorespaces Field regions of an antenna, here specifically a linear wire antenna, although they are applicable for any antenna with dimension $d$ \blx@tocontentsinit {0}\cite [p.~34]{Balanis_1997}.}}{10}{figure.caption.9}%
\contentsline {figure}{\numberline {3.1}{\ignorespaces The electric and magnetic fields corresponding to the first dominant TM mode in (a) and first dominant TE mode in (b) in a rectangular waveguide with perfectly conducting walls.}}{16}{figure.caption.10}%
\contentsline {figure}{\numberline {3.2}{\ignorespaces In this analysis, the Green's function determines the fields within the cross-sectional surface $S$ of the TEM cell, which is shown in light gray and bounded by $l$. The source exciting these fields is a centrally located electric dipole moment, $\mathbf {m}_e$.}}{18}{figure.caption.11}%
\contentsline {figure}{\numberline {3.3}{\ignorespaces Transverse electric field distributions in the cross section of the TEM cell for the fundamental TEM mode in (a), and the first two higher-order modes, the TE\textsubscript {01} mode in (b) and the TE\textsubscript {10} mode in (c).}}{19}{figure.caption.12}%
\contentsline {figure}{\numberline {3.4}{\ignorespaces Geometrical arrangement of the TEM cell, demonstrated with cross sections in the $xy$-plane in (a) and the $yz$-plane in (b).}}{20}{figure.caption.13}%
\contentsline {figure}{\numberline {3.5}{\ignorespaces Forward transmission coefficients $S_{12}$ of the TEM, TE\textsubscript {01}, and TE\textsubscript {10} modes in the TEM cell over frequency.}}{20}{figure.caption.14}%
\contentsline {figure}{\numberline {3.6}{\ignorespaces Electric and magnetic field distributions inside the TEM cell for the TEM mode (a), which exhibits purely transverse field components, and for the first higher-order modes: the TE\textsubscript {10} mode (b) and the TE\textsubscript {01} mode (c), both of which possess a longitudinal magnetic field component.}}{22}{figure.caption.16}%
\contentsline {figure}{\numberline {3.7}{\ignorespaces Electric dipole moment $\mathbf {m}_e$ oriented along the $y$-direction and displaced along the $x$-axis.}}{25}{figure.caption.17}%
\contentsline {figure}{\numberline {3.8}{\ignorespaces Normalized electric field distribution $\mathbf {E}_\mathrm {TEM}^\pm $ in the TEM cell excited with an input power of $\frac {1}{2}$\,W at 3\,GHz, showing the magnitude of the $y$-component (a) and the magnitude of the $x$-component (b).}}{25}{figure.caption.18}%
\contentsline {figure}{\numberline {3.9}{\ignorespaces Output power and $y$-component of $\mathbf {E}^\pm _\mathrm {TEM}$ for an electric dipole moment oriented along the $y$-axis in (a) and along the $x$-axis in (b), displaced along the $x$-axis in both cases.}}{26}{figure.caption.19}%
\contentsline {figure}{\numberline {3.10}{\ignorespaces TEM cell with an arbitrary current source $\mathbf {J}_1$ along the line $\boldsymbol {\tau }$ \blx@tocontentsinit {0}\cite {Collin_2015}. $\mathbf {E}$ and $\mathbf {H}$ are the field intensities induced by the current. $\mathbf {e}^+_n$ and $\mathbf {e}^-_n$ are outgoing fields towards both output ports of the TEM cell. $S_1$ and $S_2$ denote the surfaces at the output ports, and $d\mathbf {s}_1'$, $d\mathbf {s}_2'$ the corresponding outward-directed vector surface elements.}}{27}{figure.caption.20}%
